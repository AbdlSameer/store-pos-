# ── Database ─────────────────────────────────────────────
DATABASE_URL="postgresql://toystore:toystore_dev_pass@localhost:5432/toystore_db"

# ── Redis ─────────────────────────────────────────────────
REDIS_URL="redis://:redis_dev_pass@localhost:6379"

# ── JWT ───────────────────────────────────────────────────
JWT_ACCESS_SECRET="change_me_access_secret_min_32_chars"
JWT_REFRESH_SECRET="change_me_refresh_secret_min_32_chars"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# ── QR Security ───────────────────────────────────────────
QR_HMAC_SECRET="change_me_qr_hmac_secret_min_32_chars"

# ── Cloudinary ────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# ── SendGrid ──────────────────────────────────────────────
SENDGRID_API_KEY=""
SENDGRID_FROM_EMAIL="noreply@toystore.com"
ADMIN_ALERT_EMAIL="admin@toystore.com"

# ── Twilio ────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_FROM_NUMBER=""
ADMIN_ALERT_PHONE=""

# ── App ───────────────────────────────────────────────────
PORT=4000
NODE_ENV="development"
CLIENT_URL="http://localhost:5173"
