    "otplib": "^13.4.1",
    "pdfkit": "^0.15.0",
    "qrcode": "^1.5.4",
    "rate-limit-redis": "^4.2.0",
    "slugify": "^1.6.6",
    "socket.io": "^4.7.5",
    "speakeasy": "^2.0.0",
    "twilio": "^5.2.0",
    "uuid": "^10.0.0",
    "winston": "^3.19.0",
    "zod": "^3.23.8"
